{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": "{videos/**,dot-collision-art/**,static/*.png,static/*.jpg,static/*.webp,static/archive/**,static/audio/**,static/bgm/**,static/city/images/**,static/exit/**,static/images/**,static/observer/**,typhoon-news/**}"
      }
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "typhoon-news/**",
      "use": "@vercel/static"
    },
    {
      "src": "videos/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
